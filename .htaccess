RewriteEngine On

# Redirect all requests to index.php for SPA routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L]

# Security: Deny access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|md|log|ini|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security: Deny access to config files
<Files "config/*">
    Order allow,deny
    Deny from all
</Files>

# Security: Deny access to api files except index.php
<FilesMatch "^((?!index\.php).)*$">
    <If "%{REQUEST_URI} =~ m#^/api/#">
        Order allow,deny
        Deny from all
    </If>
</FilesMatch>
