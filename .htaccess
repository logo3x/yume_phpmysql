RewriteEngine On
RewriteBase /

# API routing - route /api/* to api/index.php
RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api/index.php?_route=$1 [QSA,L]

# Serve static files (css, js, images)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Serve directories (uploads, backups)
RewriteCond %{REQUEST_URI} ^/(uploads|backups)/
RewriteRule ^ - [L]

# Everything else -> index.php (SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L]
